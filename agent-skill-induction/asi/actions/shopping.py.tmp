    Returns:
        None
        
    Examples:
        add_lowest_price_product_to_cart([0, 1], '1492')
        add_lowest_price_product_to_cart([0, 1, 2], 1492)
    """
    lowest_tab_index = compare_products_by_unit_price(tab_ids)
    tab_focus(lowest_tab_index)
    add_product_to_cart(add_to_cart_button_id)

def add_product_from_best_tab(tab_ids: list, add_to_cart_button_id: str | int):
