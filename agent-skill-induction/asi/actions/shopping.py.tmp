def get_order_info_by_date_and_product(start_date: str, end_date: str, product_name: str, info_type: str):
    """Retrieve order information for a specific product purchased within a date range.
    
    Args:
        start_date: Start date in format "YYYY-MM-DD"
        end_date: End date in format "YYYY-MM-DD"
        product_name: Name of the product to search for in orders
        info_type: Type of configuration to retrieve (e.g., "price", "size", "color")
        
    Returns:
        dict: Contains order details and product configuration information
        
    Examples:
        get_order_info_by_date_and_product("2023-01-01", "2023-01-31", "fake tree", "price")
    """
    orders = magento_checkout_server_list_orders(start_date=start_date, end_date=end_date)
    
    for order in orders:
        order_details = magento_checkout_server_get_order_details(order["order_id"])
        for item in order_details.get("items", []):
            if product_name.lower() in item.get("name", "").lower():
                product_id = item.get("product_id")
                product_details = magento_product_server_get_product_details(product_id)
                return {"order_id": order["order_id"], "product": product_details, "info_type": info_type}
    
    return None

def extract_product_criticisms(product_id: str):
    """Extract negative criticisms from product reviews and send summary to user.
    
    Args:
        product_id: The product ID to retrieve reviews for
        
    Returns:
        None (sends message to user with extracted criticisms)
        
    Examples:
        extract_product_criticisms("B0848QB12J")
    """
    reviews = magento_review_server_get_product_reviews(product_id)
    
    criticisms = []
    for review in reviews:
        rating = review.get("rating", 5)
        
        if rating <= 3:
            title = review.get("title", "")
            detail = review.get("detail", "")
            
            if title:
                criticisms.append(f"Title: {title}")
            if detail:
                criticisms.append(f"Detail: {detail}")
    
    if criticisms:
        message = "Main criticisms of this product:\n\n"
        for i, criticism in enumerate(criticisms, 1):
            message += f"{i}. {criticism}\n"
        send_msg_to_user(message)
    else:
        send_msg_to_user("No significant criticisms found in the reviews.")

def extract_product_criticisms(product_id: str):
    """Extract main criticisms from product reviews (ratings 1-3 stars).
    
    Args:
        product_id: The product ID or SKU to extract criticisms for
        
    Returns:
        A list of criticism strings extracted from low-rated reviews
        
    Examples:
        extract_product_criticisms("B01488F40K")
        extract_product_criticisms("123456")
    """
    reviews = magento_review_server_get_product_reviews(product_id)
    
    criticisms = []
    for review in reviews:
        rating = review.get("rating", 5)
        
        if rating <= 3:
            title = review.get("title", "")
            detail = review.get("detail", "")
            
            if title:
                criticisms.append(f"**{title}**")
            if detail:
                criticisms.append(f"{detail}")
            criticisms.append("")
    
    return criticisms


def send_criticisms_message(criticisms: list, product_name: str = "this product"):
    """Send extracted criticisms to the user with proper formatting.
    
    Args:
        criticisms: List of criticism strings to send
        product_name: Name of the product for context (optional)
        
    Examples:
        send_criticisms_message(criticisms, "Sensodyne Repair & Protect Whitening Toothpaste")
        send_criticisms_message(criticisms)
    """
    if criticisms:
        message = f"Main criticisms of {product_name}:\n\n"
        message += "\n".join(criticisms)
        send_msg_to_user(message)
    else:
        send_msg_to_user(f"No significant criticisms found in the reviews (all reviews are 4-5 stars).")

def get_latest_order_by_status(customer_email: str, order_status: str) -> dict:
    """Retrieve the latest order for a customer with a specific status.
    
    Args:
        customer_email: The customer's email address
        order_status: The order status to filter by (e.g., 'processing', 'pending', 'shipped')
        
    Returns:
        A dictionary containing the latest order details with status, or the most recent alternative order if none match
        
    Examples:
        get_latest_order_by_status('emma.lopez@gmail.com', 'processing')
        get_latest_order_by_status('john.doe@email.com', 'shipped')
    """
    orders_with_status = magento_checkout_server_list_orders(customer_email=customer_email, status=order_status)
    
    if orders_with_status:
        latest_order = orders_with_status[0]
        return latest_order
    
    all_customer_orders = magento_checkout_server_list_orders(customer_email=customer_email)
    if all_customer_orders:
        latest_order = all_customer_orders[0]
        return latest_order
    
    return {}

