def get_order_info_by_number(order_number: str, info_type: str) -> str:
    """Retrieve specific information for an order by order number.
    
    Args:
        order_number: The order number to look up (e.g., "148", "00178")
        info_type: The type of information to retrieve (e.g., "order date", "billing address")
        
    Returns:
        str: A formatted message with the requested order information
        
    Examples:
        get_order_info_by_number("148", "order date")
        get_order_info_by_number("00178", "billing address")
    """
    order_details = magento_checkout_server_get_order_details(order_number)
    
    if info_type.lower() == "order date":
        order_date = order_details.get("created_at", "Not available")
        return f"The order date for order number {order_number} is {order_date}."
    elif info_type.lower() == "billing address":
        billing_info = order_details.get("billing_address", {})
        address = f"{billing_info.get('firstname')} {billing_info.get('lastname')}, {billing_info.get('street')}, {billing_info.get('city')}, {billing_info.get('region')}, {billing_info.get('postcode')}, {billing_info.get('country_id')}"
        return f"The billing address for order #{order_number} is: {address}"
    else:
        return f"Information type '{info_type}' not supported for order {order_number}."

