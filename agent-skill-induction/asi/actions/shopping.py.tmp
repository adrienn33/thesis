def add_lowest_price_product_to_cart(tab_ids: list, add_to_cart_button_id: str | int):
    """Compare products across tabs by unit price and add the lowest priced product to cart.
    
    Args:
        tab_ids: List of tab indices to compare (e.g., [0, 1])
