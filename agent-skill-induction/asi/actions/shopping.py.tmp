def find_reviewers_by_keyword(product_id: str, keywords: list) -> list:
    """Find reviewers who mention specific keywords in their reviews.
    
    Args:
        product_id: The product ID to get reviews for
        keywords: List of keywords to search for in reviews
        
    Returns:
        List of reviewer dictionaries containing reviewer info and review details
        
    Examples:
        reviewers = find_reviewers_by_keyword("B00JXLGF06", ["customer service", "support", "complaint"])
        reviewers = find_reviewers_by_keyword("PROD123", ["quality", "durability"])
    """
    reviews = magento_review_server_get_product_reviews(product_id)
    
    reviewers_found = []
    
    for review in reviews:
        review_content = (review.get("detail", "") + " " + review.get("title", "")).lower()
        
        for keyword in keywords:
            if keyword.lower() in review_content:
                reviewers_found.append({
                    "reviewer": review.get("nickname", "Unknown"),
                    "title": review.get("title", ""),
                    "detail": review.get("detail", ""),
                    "rating": review.get("rating", "N/A")
                })
                break
    
    return reviewers_found


def send_reviewers_list(reviewers_info: list, mention_type: str):
    """Send a formatted list of reviewers to the user.
    
    Args:
        reviewers_info: List of reviewer dictionaries from find_reviewers_by_keyword
        mention_type: Description of what the reviewers mentioned (e.g., "customer service complaints")
        
    Returns:
        None
        
    Examples:
        send_reviewers_list(reviewers, "customer service complaints")
        send_reviewers_list(reviewers, "quality issues")
    """
    if reviewers_info:
        message = f"Found {len(reviewers_info)} reviewer(s) who mentioned {mention_type}:\n\n"
        for i, reviewer_info in enumerate(reviewers_info, 1):
            message += f"{i}. **{reviewer_info['reviewer']}** (Rating: {reviewer_info['rating']}/5)\n"
            message += f"   Title: {reviewer_info['title']}\n"
            message += f"   Comment: {reviewer_info['detail'][:150]}...\n\n"
        send_msg_to_user(message)
    else:
        send_msg_to_user(f"No reviewers mentioned {mention_type} for this product.")

