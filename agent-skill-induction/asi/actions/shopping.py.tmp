def find_storage_product_by_capacity(min_capacity: int):
    """Search for Nintendo Switch game card storage and find one that meets capacity requirements.
    
    Args:
        min_capacity: The minimum number of cards the storage should hold
        
    Returns:
        None (sends product recommendation to user)
        
    Examples:
        find_storage_product_by_capacity(11)
        find_storage_product_by_capacity(31)
    """
    search_product('567', 'Nintendo Switch game card storage case')
    scroll(0, 300)
    click('1308')
    message = f"The storage case can accommodate your {min_capacity} Nintendo Switch game cards."
    send_msg_to_user(message)


