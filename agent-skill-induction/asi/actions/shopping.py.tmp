def send_order_info(order_number: str, info_type: str, info_value: str):
    """Send order information to the user.
    
    Args:
        order_number: The order number (e.g., "00178")
        info_type: The type of information (e.g., "billing address", "shipping address")
        info_value: The actual information content
        
    Returns:
        None (sends message to user)
        
    Examples:
        send_order_info("00178", "billing address", "Emma Lopez, 101 S San Mateo Dr, San Mateo, California, 94010, United States")
    """
    message = f"The {info_type} for order #{order_number} is: {info_value}"
    send_msg_to_user(message)

def get_order_by_status(customer_email: str, order_status: str):
    """Retrieve the most recent order with a specific status for a customer.
    
    Args:
        customer_email: The customer's email address
        order_status: The desired order status (e.g., "under delivery", "pending", "completed")
        
    Returns:
        dict: The most recent order matching the status, containing 'increment_id' and other order details
        
    Examples:
        get_order_by_status("emma.lopez@gmail.com", "under delivery")
        get_order_by_status("john.doe@gmail.com", "pending")
    """
    orders = magento_checkout_server_list_orders(customer_email=customer_email)
    matching_orders = [order for order in orders if order.get('status') == order_status]
    if matching_orders:
        return matching_orders[0]
    return None


def send_most_recent_order_number(customer_email: str, order_status: str):
    """Send the order number of the most recent order with a specific status.
    
    Args:
        customer_email: The customer's email address
        order_status: The desired order status (e.g., "under delivery", "pending")
        
    Returns:
        None (sends message to user or reports if no order found)
        
    Examples:
        send_most_recent_order_number("emma.lopez@gmail.com", "under delivery")
    """
    order = get_order_by_status(customer_email, order_status)
    if order:
        order_number = order.get('increment_id')
        message = f"The order number of your most recent {order_status} order is: {order_number}"
        send_msg_to_user(message)
    else:
        message = f"No {order_status} orders found."
        send_msg_to_user(message)

def search_storage_product(search_bar_id: str | int, product_name: str, required_capacity: int):
    """Search for a storage product and identify options that meet capacity requirements.
    
    Args:
        search_bar_id: The ID of the search bar element
        product_name: The name/type of storage product to search for
        required_capacity: The minimum number of items the storage should hold
        
    Returns:
        None (displays search results for user to browse)
        
    Examples:
        search_storage_product('567', 'Nintendo Switch game card storage case', 11)
        search_storage_product('179', 'Nintendo Switch game card storage', 31)
    """
    click(search_bar_id)
    fill(search_bar_id, product_name)
    keyboard_press("Enter")

def get_most_recent_order_by_status(customer_email: str, order_status: str):
    """Retrieve and display the most recent order with a specific status.
    
    Args:
        customer_email: The customer's email address
        order_status: The order status to filter by (e.g., 'processing', 'completed')
        
    Returns:
        None (sends formatted order information to user)
        
    Examples:
        get_most_recent_order_by_status('emma.lopez@gmail.com', 'processing')
        get_most_recent_order_by_status('john.doe@gmail.com', 'pending')
    """
    orders = magento_checkout_server_list_orders(customer_email=customer_email, status=order_status)
    
    if orders:
        latest_order = orders[0]
        order_number = latest_order.get('increment_id', 'N/A')
        order_date = latest_order.get('created_at', 'N/A')
        order_total = latest_order.get('grand_total', 'N/A')
        
        message = f"Your most recent {order_status} order is:\n\n"
        message += f"Order Number: {order_number}\n"
        message += f"Date: {order_date}\n"
        message += f"Total: ${order_total}\n"
        message += f"Status: {order_status.capitalize()}"
        
        send_msg_to_user(message)
    else:
        send_msg_to_user(f"No {order_status} orders found.")

def find_last_order_with_product(customer_email: str, product_description: str) -> dict:
    """Find the most recent order containing a specific product for a customer.
    
    Args:
        customer_email: The customer's email address
        product_description: Description of the product to search for (e.g., "toothpaste")
        
    Returns:
        A dictionary containing order details with keys:
        - 'order_number': The order ID
        - 'order_date': The date of the order
        - 'product_name': The full product name
        
    Examples:
        result = find_last_order_with_product("emma.lopez@gmail.com", "toothpaste")
        # Returns: {'order_number': '000000174', 'order_date': 'December 4, 2022', 
        #           'product_name': 'LG Perioe Total 7 Toothpaste - Original Advance 4.2oz (120g) * 3packs'}
    """
    orders = magento_checkout_server_list_orders(customer_email=customer_email)
    
    for order in orders:
        order_details = magento_checkout_server_get_order_details(order['order_id'])
        for item in order_details.get('items', []):
            if product_description.lower() in item.get('product_name', '').lower():
                return {
                    'order_number': order_details['order_id'],
                    'order_date': order_details['order_date'],
                    'product_name': item['product_name']
                }
    
    return {}


def send_last_order_message(order_info: dict, product_description: str):
    """Send a message to the user about their last product order.
    
    Args:
        order_info: Dictionary containing order_number, order_date, and product_name
        product_description: The product description (e.g., "toothpaste")
        
    Examples:
        order_info = {'order_number': '000000174', 'order_date': 'December 4, 2022', 
                      'product_name': 'LG Perioe Total 7 Toothpaste - Original Advance 4.2oz (120g) * 3packs'}
        send_last_order_message(order_info, "toothpaste")
    """
    if order_info:
        message = f"You last ordered {product_description} on {order_info['order_date']}. The order was for '{order_info['product_name']}' (Order #{order_info['order_number']})."
        send_msg_to_user(message)
    else:
        message = f"No previous orders found containing {product_description}."
        send_msg_to_user(message)

