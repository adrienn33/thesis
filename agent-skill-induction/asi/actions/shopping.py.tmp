def navigate_to_and_view_order(account_id: str, view_all_id: str, page_ids: list, order_view_id: str, order_number: str):
    """Navigate to order history and open a specific order details page.
    
    Args:
        account_id: The ID of the "My Account" link
        view_all_id: The ID of the "View All" orders link
        page_ids: List of page link IDs to navigate through pagination
        order_view_id: The ID of the "View Order" link for the target order
        order_number: The order number being searched for (for reference)
        
    Returns:
        None
        
    Examples:
        navigate_to_and_view_order('227', '1742', ['1816'], '1780', '00245')
    """
    click(account_id)
    click(view_all_id)
    for page_id in page_ids:
        click(page_id)
    click(order_view_id)


def send_order_address_info(order_number: str, info_type: str, recipient_name: str, street: str, city: str, state: str, postal_code: str, country: str):
    """Send order address information to the user.
    
    Args:
        order_number: The order number
        info_type: Type of address ("billing address" or "shipping address")
        recipient_name: Name of the recipient
        street: Street address
        city: City name
        state: State name
        postal_code: Postal code
        country: Country name
        
    Returns:
        None
        
    Examples:
        send_order_address_info('00245', 'shipping address', 'James Martinez', '456 Oak Avenue', 'Denver', 'Colorado', '80202', 'United States')
    """
    address_str = f"{recipient_name}, {street}, {city}, {state}, {postal_code}, {country}"
    message = f"The {info_type} for order #{order_number} is: {address_str}"
    send_msg_to_user(message)

def find_and_report_storage_product(search_bar_id: str | int, search_query: str, product_link_id: str | int, product_name: str, capacity: int, required_capacity: int, price: str = ""):
    """Search for a storage product, view details, and report to user if capacity is sufficient.
    
    Args:
        search_bar_id: The ID of the search bar element
        search_query: The search query for storage products
        product_link_id: The ID of the product link to click
        product_name: The name of the storage product
        capacity: The storage capacity of the product
        required_capacity: The user's required storage capacity
        price: The product price (optional)
        
    Returns:
        None
        
    Examples:
        find_and_report_storage_product('179', 'Nintendo Switch game card storage', '1420', 'Premium Game Card Storage Case for Nintendo Switch - 60 Card Capacity', 60, 50, '$14.99')
    """
    search_product(search_bar_id, search_query)
    scroll(0, 300)
    click(product_link_id)
    
    if capacity >= required_capacity:
        message = f"The '{product_name}' can store up to {capacity} Nintendo Switch game cards, which will fit all {required_capacity} of your cards."
        if price:
            message += f" The price is {price}."
        send_msg_to_user(message)
    else:
        send_msg_to_user(f"The '{product_name}' stores only {capacity} cards, which is not sufficient for {required_capacity} cards. Please consider a larger storage option.")

