  },
  "intent": "What is the rating of Ugreen lightning to 3.5mm cable. Please round to the nearest whole number",
  "require_reset": false,
  "eval": {
    "eval_types": [
      "string_match"
    ],
    "reference_answers": {
      "must_include": [
        "65 |OR| 3"
      ]
    },
    "reference_url": "",
    "program_html": [],
    "string_note": "",
    "reference_answer_raw_annotation": "Around 3.1 stars"
  },
  "intent_template_id": 1355,
  "mcp_servers": [
    {
