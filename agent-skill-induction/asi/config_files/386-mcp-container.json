{
  "sites": [
    "shopping"
  ],
  "task_id": "386-mcp-container",
  "require_login": true,
  "storage_state": "./.auth/shopping_state.json",
  "start_url": "localhost:7770",
  "geolocation": null,
  "intent_template": "What is the rating of {{product}}",
  "instantiation_dict": {
